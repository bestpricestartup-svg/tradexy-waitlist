# Vercel upload exclusions (100 MB limit) — never upload local deps or build output

# Dependencies (installed on Vercel via npm ci / install)
node_modules
**/node_modules

# Next.js build & caches
.next
**/.next
out
.turbo
**/.turbo
dist
build

# Git (if present locally)
.git
**/.git

# Environment & secrets (set in Vercel Project Settings)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Test / coverage
coverage
.nyc_output

# OS / IDE
.DS_Store
Thumbs.db
.idea
.vscode
*.swp
*.swo

# TypeScript incremental
*.tsbuildinfo

# Vercel local link (regenerated in cloud)
.vercel

# Misc caches
.cache
.parcel-cache
.eslintcache
