# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_or_secret_key

# --- Site (production: https://tradexyai.com) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# El. laiškas: tik public/tradexy-email-logo.png (inline; jokių kitų URL / env override)

# --- Admin (vienintelis leistinas el. paštas /admin/login OTP) ---
ADMIN_EMAIL=bestpricestartup@gmail.com

# --- Resend (production: domenas patvirtintas, siuntimas iš hello@tradexyai.com) ---
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=Tradexy <hello@tradexyai.com>

# --- Admin sesijos slapukas (production: būtina unikali paslaptis) ---
ADMIN_SESSION_SECRET=

# Pastaba: memory OTP ir API `debug` laukai veikia tik `next dev` (NODE_ENV=development).
